{
  "name": "@stbr/sss-token",
  "version": "0.1.0",
  "description": "Solana Stablecoin Standard (SSS) - SDK, CLI, and Programs",
  "main": "sdk/dist/index.js",
  "types": "sdk/dist/index.d.ts",
  "scripts": {
    "build": "tsc -p sdk/tsconfig.json",
    "build:anchor": "anchor build",
    "test": "ts-mocha -p ./tsconfig.json 'tests/*.test.ts'",
    "test:anchor": "anchor test",
    "lint": "eslint sdk/src/**/*.ts cli/src/**/*.ts backend/src/**/*.ts --ext .ts || true",
    "lint:fix": "eslint sdk/src/**/*.ts cli/src/**/*.ts backend/src/**/*.ts --ext .ts --fix || true",
    "cli": "ts-node cli/src/index.ts",
    "backend": "ts-node backend/src/index.ts",
    "ci": "npm run lint && npm run build"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/spl-token": "^0.4.8",
    "@solana/spl-token-metadata": "^0.1.5",
    "@solana/web3.js": "^1.95.0",
    "bn.js": "^5.2.1",
    "commander": "^12.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.5",
    "@types/chai": "^4.3.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/mocha": "^9.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "chai": "^4.3.4",
    "eslint": "^8.57.0",
    "mocha": "^9.0.3",
    "ts-mocha": "^10.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
