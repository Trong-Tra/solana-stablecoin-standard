  "accounts": [
    {
      "name": "StablecoinState",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "masterAuthority", "type": "publicKey" },
          { "name": "mint", "type": "publicKey" },
          { "name": "name", "type": "string" },
          { "name": "symbol", "type": "string" },
          { "name": "uri", "type": "string" },
          { "name": "decimals", "type": "u8" },
          { "name": "features", "type": { "defined": "FeatureFlags" } },
          { "name": "paused", "type": "bool" },
          { "name": "totalMinted", "type": "u64" },
          { "name": "totalBurned", "type": "u64" },
          { "name": "bump", "type": "u8" },
          { "name": "version", "type": "u8" }
        ]
      }
    },
    {
      "name": "MinterState",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "minter", "type": "publicKey" },
          { "name": "mint", "type": "publicKey" },
          { "name": "quota", "type": "u64" },
          { "name": "minted", "type": "u64" },
          { "name": "active", "type": "bool" },
          { "name": "bump", "type": "u8" }
        ]
      }
    },
    {
      "name": "BurnerState",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "burner", "type": "publicKey" },
          { "name": "mint", "type": "publicKey" },
          { "name": "active", "type": "bool" },
          { "name": "bump", "type": "u8" }
        ]
      }
    },
    {
      "name": "BlacklistEntry",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "address", "type": "publicKey" },
          { "name": "mint", "type": "publicKey" },
          { "name": "reason", "type": "string" },
          { "name": "addedAt", "type": "i64" },
          { "name": "addedBy", "type": "publicKey" }
        ]
      }
    }
  ],
  "types": [
    {
      "name": "StablecoinConfig",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "name", "type": "string" },
          { "name": "symbol", "type": "string" },
          { "name": "uri", "type": "string" },
          { "name": "decimals", "type": "u8" },
          { "name": "enablePermanentDelegate", "type": "bool" },
          { "name": "enableTransferHook", "type": "bool" },
          { "name": "defaultAccountFrozen", "type": "bool" }
        ]
      }
    },
    {
      "name": "FeatureFlags",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "permanentDelegate", "type": "bool" },
          { "name": "transferHook", "type": "bool" },
          { "name": "defaultAccountFrozen", "type": "bool" },
          { "name": "confidentialTransfers", "type": "bool" }
        ]
      }
    }
  ],
  "errors": [
    { "code": 6000, "name": "Unauthorized", "msg": "Unauthorized: caller does not have required role" },
    { "code": 6001, "name": "InvalidPreset", "msg": "Invalid preset configuration" },
    { "code": 6002, "name": "Paused", "msg": "Stablecoin is paused" },
    { "code": 6003, "name": "AccountFrozen", "msg": "Account is frozen" },
    { "code": 6004, "name": "Blacklisted", "msg": "Address is blacklisted" },
    { "code": 6005, "name": "ComplianceNotEnabled", "msg": "Compliance module not enabled" },
    { "code": 6006, "name": "QuotaExceeded", "msg": "Minter quota exceeded" },
    { "code": 6007, "name": "InvalidAmount", "msg": "Invalid amount" },
    { "code": 6008, "name": "InvalidDecimals", "msg": "Invalid decimals" },
    { "code": 6009, "name": "NameTooLong", "msg": "Name too long (max 32 chars)" },
    { "code": 6010, "name": "SymbolTooLong", "msg": "Symbol too long (max 10 chars)" },
    { "code": 6011, "name": "UriTooLong", "msg": "URI too long (max 200 chars)" },
    { "code": 6012, "name": "ReasonTooLong", "msg": "Reason too long (max 100 chars)" },
    { "code": 6013, "name": "AlreadyExists", "msg": "Account already exists" },
    { "code": 6014, "name": "NotFound", "msg": "Account not found" },
    { "code": 6015, "name": "OutstandingSupply", "msg": "Cannot close: outstanding supply exists" },
    { "code": 6016, "name": "NoPermanentDelegate", "msg": "Permanent delegate not set" },
    { "code": 6017, "name": "TransferHookNotEnabled", "msg": "Transfer hook not enabled" },
    { "code": 6018, "name": "InvalidAuthority", "msg": "Invalid authority" },
    { "code": 6019, "name": "MathOverflow", "msg": "Math overflow" },
    { "code": 6020, "name": "ExtensionError", "msg": "Token-2022 extension error" },
    { "code": 6021, "name": "MetadataError", "msg": "Metadata error" }
