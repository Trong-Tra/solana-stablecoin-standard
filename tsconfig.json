{
  "compilerOptions": {
    "lib": ["es2020"],
    "module": "commonjs",
    "target": "es2020",
    "esModuleInterop": true,
    "strict": true,
    "resolveJsonModule": true,
    "declaration": true,
    "outDir": "./dist",
    "rootDir": ".",
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "sdk/**/*",
    "cli/**/*",
    "backend/**/*",
    "tests/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "target"
  ]
}
